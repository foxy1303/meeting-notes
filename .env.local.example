FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
WHISPER_CPP_BIN=/opt/homebrew/bin/whisper-cli
WHISPER_CPP_MODEL=/absolute/path/to/models/ggml-base.bin
MAX_UPLOAD_MB=200

# Preferred chat/completions config. Works locally and in Docker.
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=
AI_MODEL=qwen3.5-122b
SUMMARY_CHUNK_CHARS=12000

# Optional fallback: read the model config from openCode if AI_BASE_URL/AI_MODEL
# are not set.
OPENCODE_CONFIG_PATH=/opencode.json
OPENCODE_PROVIDER=llm-bridge
OPENCODE_MODEL=smart-fast
