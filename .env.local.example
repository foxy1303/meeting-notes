# Local npm run dev on macOS/Homebrew:
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# WHISPER_CPP_BIN=/opt/homebrew/bin/whisper-cli
# WHISPER_CPP_MODEL=/absolute/path/to/project/models/ggml-base.bin

# Docker compose:
WHISPER_CPP_REF=master
APP_PORT=3000
FFMPEG_BIN=ffmpeg
WHISPER_CPP_BIN=whisper-cli
WHISPER_CPP_MODEL=/app/models/ggml-base.bin

# Preferred chat/completions config. Works locally and in Docker.
# Use http://localhost:11434/v1 for local npm run dev if the model server runs locally.
# Use http://host.docker.internal:11434/v1 for Docker if the model server runs on the host.
AI_BASE_URL=http://host.docker.internal:11434/v1
AI_API_KEY=
AI_MODEL=your-chat-model
SUMMARY_CHUNK_CHARS=12000
MAX_UPLOAD_MB=200
MAX_ACTIVE_TRANSCRIPTIONS=1

# Optional fallback: read the model config from openCode if AI_BASE_URL/AI_MODEL
# are not set.
OPENCODE_CONFIG_PATH=/path/to/opencode.json
OPENCODE_PROVIDER=your-provider
OPENCODE_MODEL=your-model
